# Generated by Cargo
target/

# Remove Cargo.lock from gitignore if creating an executable program
# More info: https://doc.rust-lang.org/cargo/guide/cargo-toml-vs-cargo-lock.html
Cargo.lock

# Backup files
*.rs.bk

# IDE / Editor settings
.vscode/
.idea/
*.swp
*.swo
.claude/*
!.claude/CLAUDE.md

# macOS
.DS_Store

# Windows
Thumbs.db
Desktop.ini

# Environment variables
.env

# Telemetry runtime artifacts (anonymous instance ID files)
.anon_id
**/.anon_id

# C API build artifacts
capi/build/
capi/build-*/

# JS/Neon build artifacts
js/cognee-neon/target/
js/node_modules/
js/lib/
js/cognee_neon.node

# JS lockfile — only pins dev-deps (jest, ts-jest, typescript); regeneration
# under older Node versions produces churn (lockfileVersion 1 vs 3).
js/package-lock.json

# Python cache
__pycache__/
*.pyc
*.pyo
