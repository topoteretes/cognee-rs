Cargo.lock

# Backup files
*.rs.bk

# IDE / Editor settings
.vscode/
.idea/
*.swp
*.swo
.claude/*
!.claude/CLAUDE.md

# macOS
.DS_Store

# Windows
Thumbs.db
Desktop.ini

# Environment variables
.env

# Telemetry runtime artifacts (anonymous instance ID files)
.anon_id
**/.anon_id

# C API build artifacts
capi/build/
capi/build-*/

# TS/Neon build artifacts
ts/cognee-ts-neon/target/
ts/node_modules/
ts/lib/
ts/cognee_ts_neon.node
ts/.cognee_system/
ts/.data_storage/
ts/cognee.db

# TS lockfile — only pins dev-deps (jest, ts-jest, typescript); regeneration
# under older Node versions produces churn (lockfileVersion 1 vs 3).
ts/package-lock.json

# Python cache
__pycache__/
*.pyc
*.pyo

# Local scratch workspace files
.tmp/

# Runtime data storage (created by CLI in cwd)
.data_storage/

# Runtime artifacts written into cwd by un-isolated test runs (any directory)
cognee.db
.cognee_system/

# Generated Locust benchmark artifacts
e2e-cross-sdk/performance/locust/results/
results/
