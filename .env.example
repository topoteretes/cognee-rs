# Copy this to .env and modify as needed
RUST_LOG=info
RUST_TEST_NOCAPTURE=1

# LLM API Configuration (for integration tests)
# For local Ollama: http://localhost:11435/v1
# For OpenAI: https://api.openai.com/v1
OPENAI_URL=http://localhost:11435/v1
OPENAI_TOKEN=not-needed

# CLI live smoke tests (ignored by default in cargo test)
# Used by crates/cognee-cli/tests/cli_e2e.rs ignored tests
COGNEE_E2E_EMBED_MODEL_PATH=/absolute/path/to/BGE-Small-v1.5-model_quantized.onnx
COGNEE_E2E_TOKENIZER_PATH=/absolute/path/to/bge-small-tokenizer.json

# Android NDK toolchain setup
ANDROID_NDK_HOME=/path/to/android-ndk
ANDROID_SDK_ROOT=/path/to/Android/Sdk
PATH=$ANDROID_NDK_HOME/toolchains/llvm/prebuilt/linux-x86_64/bin:$PATH