###############################################################################
# TIER 1 — QUICK START
# Set this one variable and you're done. Everything else has working defaults.
# Default databases (SQLite, embedded Ladybug graph, embedded Qdrant) are
# file-based — no external services needed.
###############################################################################
LLM_API_KEY="your_api_key"


###############################################################################
# TIER 2 — COMMON OVERRIDES (uncomment to customize)
# Most users only need a few of these.
###############################################################################

# -- LLM Provider & Model -----------------------------------------------------
#LLM_MODEL="gpt-4.1-mini"
#LLM_PROVIDER="openai"
#LLM_ENDPOINT=""                  # e.g. http://localhost:11434/v1 for Ollama

# -- Embedding Provider --------------------------------------------------------
#EMBEDDING_PROVIDER="onnx"        # onnx (local default) | openai | ollama
#EMBEDDING_MODEL=""
# Vector dimension resolution order: explicit EMBEDDING_DIMENSIONS below always
# wins; otherwise it is auto-derived from the known-model table for the chosen
# EMBEDDING_MODEL (e.g. text-embedding-3-large -> 3072, bge-small -> 384);
# unknown models fall back to 384 with a warning. ONNX uses the model file's
# dimension. NOTE: matching dimensions does NOT make different models'
# vectors interoperable — cross-SDK reads need the *same* embedder.
#EMBEDDING_DIMENSIONS=384

# -- Database Providers (switch from file-based defaults) ----------------------
#DB_PROVIDER="postgres"           # sqlite (default) | postgres
#DB_HOST=127.0.0.1
#DB_PORT=5432
#DB_USERNAME=cognee
#DB_PASSWORD=cognee
#DB_NAME=cognee_db

#GRAPH_DATABASE_PROVIDER="ladybug"   # ladybug (default, embedded)
#VECTOR_DB_PROVIDER="qdrant"         # qdrant (default, embedded) | pgvector

# -- Ontology (optional) -------------------------------------------------------
#ONTOLOGY_FILE_PATH=""               # path to .ttl / .rdf / .owl ontology file
#ONTOLOGY_RESOLVER="rdflib"          # rdflib (default)
#ONTOLOGY_MATCHING_STRATEGY="fuzzy"  # fuzzy (default)


###############################################################################
# TIER 3 — ADVANCED (grouped by subsystem)
# Most users never need to change anything below this line.
###############################################################################

################################################################################
#  LLM — Advanced Settings
################################################################################
#LLM_MAX_TOKENS=16384
#LLM_API_VERSION=""               # needed for Azure OpenAI
#LLM_TEMPERATURE=0.0
#LLM_MAX_RETRIES=2
#LLM_MAX_PARALLEL_REQUESTS=20

################################################################################
#  Embedding — Advanced Settings
################################################################################
#EMBEDDING_ENDPOINT=""
#EMBEDDING_API_VERSION=""
#EMBEDDING_MAX_SEQUENCE_LENGTH=512
#EMBEDDING_BATCH_SIZE=32
# If not provided, LLM_API_KEY is also used for embeddings.
#EMBEDDING_API_KEY="your_api_key"
# Paths for the local ONNX model (auto-downloaded to target/models/ by default).
#EMBEDDING_MODEL_PATH="./target/models/BGE-Small-v1.5-model_quantized.onnx"
#EMBEDDING_TOKENIZER_PATH="./target/models/bge-small-tokenizer.json"

################################################################################
#  Relational Database — Advanced
################################################################################
DB_PROVIDER="sqlite"
# Full SQLite URL (alternative to the individual DB_* fields above).
#DATABASE_URL="sqlite:./cognee.db"

################################################################################
#  Graph Database — Advanced
################################################################################
GRAPH_DATABASE_PROVIDER="ladybug"
#GRAPH_DATABASE_URL=""
#GRAPH_DATABASE_NAME=""
#GRAPH_DATABASE_USERNAME=""
#GRAPH_DATABASE_PASSWORD=""
#GRAPH_DATABASE_PORT=""
#GRAPH_FILE_PATH=""               # override graph storage directory

################################################################################
#  Vector Database — Advanced
################################################################################
VECTOR_DB_PROVIDER="qdrant"
#VECTOR_DB_URL=""                 # override vector storage directory
#VECTOR_DB_KEY=""

################################################################################
#  Root Directories
################################################################################
#COGNEE_SYSTEM_ROOT_DIRECTORY="./.cognee_system"
#COGNEE_DATA_ROOT_DIRECTORY="./.data_storage"
#COGNEE_DEFAULT_DATASET_NAME="main_dataset"

################################################################################
#  Dev / Debug
################################################################################
RUST_LOG=info
TOKENIZERS_PARALLELISM=false

# -- Logging -------------------------------------------------------------------
# Full reference + multi-process caveat: see docs/configuration.md (Logging section).
#COGNEE_LOG_FILE=true                 # master toggle (false/0/no disables file logging)
#COGNEE_LOGS_DIR="~/.cognee/logs"     # falls back to /tmp/cognee_logs if unwritable
#COGNEE_LOG_FORMAT=plain              # plain (Python-compatible) | json
#COGNEE_LOG_ROTATION=daily            # daily | hourly | minutely | never
#COGNEE_LOG_BACKUP_COUNT=5            # files kept by the rotation policy
#COGNEE_LOG_MAX_FILES=10              # startup cap; older files removed
#LOG_LEVEL=info                       # fallback level; RUST_LOG wins when both set
#LOG_FILE_NAME=                       # auto-set by parent; children inherit


###############################################################################
# TIER 4 — EXAMPLE PROVIDER CONFIGURATIONS (commented out)
# Uncomment + fill values to switch providers.
###############################################################################

########## Local LLM via Ollama ################################################
#LLM_API_KEY="ollama"             # required; any non-empty value works for a local Ollama
#LLM_PROVIDER="ollama"            # routes to the OpenAI-compatible adapter; defaults the endpoint below
#LLM_MODEL="llama3.1:8b"          # an "ollama/" prefix is stripped automatically
#LLM_ENDPOINT="http://localhost:11434/v1"   # optional; this is the default for ollama
#EMBEDDING_PROVIDER="ollama"
#EMBEDDING_MODEL="nomic-embed-text:latest"
# Set EMBEDDING_ENDPOINT explicitly for the Ollama embedder (it needs /api/embed,
# not the /v1 chat base) — it does not inherit LLM_ENDPOINT.
#EMBEDDING_ENDPOINT="http://localhost:11434/api/embed"
#EMBEDDING_DIMENSIONS=768
#HUGGINGFACE_TOKENIZER="nomic-ai/nomic-embed-text-v1.5"

########## Azure OpenAI (API key auth) ########################################
#LLM_PROVIDER="azure"             # api-key auth + ?api-version= query on the OpenAI path
#LLM_MODEL="gpt-4o-mini"          # deployment name (ignored by Azure; the deployment is in the URL)
#LLM_ENDPOINT="https://YOUR-RESOURCE.openai.azure.com/openai/deployments/gpt-4o-mini"  # deployment URL, required
#LLM_API_KEY="your-azure-api-key"
#LLM_API_VERSION="2024-12-01-preview"   # required for azure
#LLM_MAX_TOKENS=16384
#EMBEDDING_MODEL="text-embedding-3-large"
#EMBEDDING_ENDPOINT="https://YOUR-RESOURCE.openai.azure.com/openai/deployments/text-embedding-3-large"
#EMBEDDING_API_KEY="your-azure-api-key"
#EMBEDDING_API_VERSION="2024-12-01-preview"
#EMBEDDING_DIMENSIONS=3072

########## PostgreSQL backend ##################################################
#DB_PROVIDER="postgres"
#DB_HOST=localhost
#DB_PORT=5432
#DB_USERNAME=cognee
#DB_PASSWORD=cognee
#DB_NAME=cognee_db
#VECTOR_DB_PROVIDER="pgvector"


###############################################################################
# TEST / CI INFRASTRUCTURE (not needed for normal use)
###############################################################################

# LLM env-var aliases used by integration tests.
# These are accepted by the CLI as fallbacks for the canonical LLM_* names above.
#OPENAI_URL=https://api.openai.com/v1    # alias for LLM_ENDPOINT
#OPENAI_TOKEN=your-api-key-here         # alias for LLM_API_KEY
#OPENAI_MODEL=gpt-4o-mini               # alias for LLM_MODEL

# Optional E2E embedding model overrides. If omitted, ONNX E2E tests download
# BGE-Small-v1.5 into target/models automatically.
#COGNEE_E2E_EMBED_MODEL_PATH=/absolute/path/to/BGE-Small-v1.5-model_quantized.onnx
#COGNEE_E2E_TOKENIZER_PATH=/absolute/path/to/bge-small-tokenizer.json
#COGNEE_TEST_MODEL_DIR=target/models

# Android NDK toolchain
#ANDROID_NDK_HOME=/path/to/android-ndk
#ANDROID_SDK_ROOT=/path/to/Android/Sdk
#PATH=$ANDROID_NDK_HOME/toolchains/llvm/prebuilt/linux-x86_64/bin:$PATH
