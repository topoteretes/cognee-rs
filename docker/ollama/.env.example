# Ollama Configuration

# Model to automatically pull on startup
MODEL_NAME=llama3.2:3b

# Comma-separated model list to ensure availability (includes stronger models)
MODEL_NAMES=llama3.2:3b,llama3.1:8b

# Container name
CONTAINER_NAME=ollama

# Port to expose Ollama on
PORT=11435

# Docker volume name for persistent storage
VOLUME_NAME=ollama_data
